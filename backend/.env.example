# ─────────────────────────────────────────────────────────────
# Velt Backend — variables de entorno (copiar a .env y rellenar)
# Nunca commitear .env. Nunca loguear secretos.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Arc (Circle testnet)
ARC_RPC_URL=
ARC_CHAIN_ID=
USDC_CONTRACT_ADDRESS=
ERC4337_BUNDLER_URL=
ERC4337_ENTRYPOINT_ADDRESS=

# Signer  (local | privy | turnkey)
SIGNER_BACKEND=local
LOCAL_SIGNER_MASTER_KEY=        # solo si SIGNER_BACKEND=local — hex privada 0x... (clave maestra para derivar owners)
# PRIVY_APP_ID=                 # solo si SIGNER_BACKEND=privy
# PRIVY_APP_SECRET=
# TURNKEY_API_KEY=              # solo si SIGNER_BACKEND=turnkey

# Auth (login de comerciante)
JWT_SECRET=                     # >=32 chars. Generar: openssl rand -base64 48
# ACCESS_TOKEN_TTL_SECONDS=900       # default 15 min
# REFRESH_TOKEN_TTL_SECONDS=2592000  # default 30 días

# Bioserver (proveedor de auth por palma) — mismas credenciales que VeltSensorConfig (Android)
# BIOSERVER_URL=https://openpalm.io/admin-app/   # default
BIOSERVER_CLIENT_ID=
BIOSERVER_SHARED_SECRET=

# Stytch (login por teléfono — OTP por SMS/WhatsApp). Dashboard → API Keys.
# STYTCH_ENV=test               # test (números sandbox, sin SMS real) | live (SMS real, plan de pago)
STYTCH_PROJECT_ID=              # project-test-... | project-live-...
STYTCH_SECRET=                  # secret-test-... | secret-live-...

# Escrow condicional (contracts/VeltEscrow.sol)
ESCROW_CONTRACT_ADDRESS=        # address tras `npm run deploy:escrow` (sin ella los pagos fallan al liquidar)
# ESCROW_RELEASE_DELAY_SECONDS=300   # default 5 min: ventana antes del auto-release
# DEPLOYER_PRIVATE_KEY=         # solo para `npm run deploy:escrow` — EOA con gas en Arc
