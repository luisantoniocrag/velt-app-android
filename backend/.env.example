# ─────────────────────────────────────────────────────────────
# Velt Backend — variables de entorno (copiar a .env y rellenar)
# Nunca commitear .env. Nunca loguear secretos.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Arc (Circle testnet)
ARC_RPC_URL=
ARC_CHAIN_ID=
USDC_CONTRACT_ADDRESS=
ERC4337_BUNDLER_URL=
ERC4337_ENTRYPOINT_ADDRESS=

# Signer  (local | privy | turnkey)
SIGNER_BACKEND=local
LOCAL_SIGNER_MASTER_KEY=        # solo si SIGNER_BACKEND=local — hex privada 0x... (clave maestra para derivar owners)
# PRIVY_APP_ID=                 # solo si SIGNER_BACKEND=privy
# PRIVY_APP_SECRET=
# TURNKEY_API_KEY=              # solo si SIGNER_BACKEND=turnkey
